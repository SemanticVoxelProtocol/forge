# Ignore everything
*

# Allow project structure
!.gitignore
!.prettierrc
!.node-version
!README.md
!CHANGELOG.md
!CONTRIBUTING.md
!CODE_OF_CONDUCT.md
!AI_POLICY.md
!SECURITY.md
!LICENSE
!tsconfig.json
!package.json
!package-lock.json
!eslint.config.ts
!vitest.config.ts
!docs/
!docs/migrations/
!docs/migrations/*.md
!docs/maintainers/
!docs/maintainers/documentation-boundaries.md
!docs/guide-openspec-svp.md
!docs/guide-openspec-svp.zh.md
!docs/pre-release-checklist.md

# Allow source directories
!packages/
!packages/**
!scripts/
!scripts/**
!tests/
!tests/**
!i18n/
!i18n/**
!.github/
!.github/**

# Within allowed dirs, re-ignore all hidden directories then whitelist specific ones
**/.*/
!**/.svp/
!**/.svp/**
!.github/
!.github/**

# Re-ignore generated/temp files within allowed dirs
tests/e2e/report-*
*.swp
*.kate-swp
*.swo
*~
