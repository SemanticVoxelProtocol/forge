# Ignore everything
*

# Allow project structure
!.gitignore
!.prettierrc
!.node-version
!README.md
!CONTRIBUTING.md
!CODE_OF_CONDUCT.md
!LICENSE
!tsconfig.json
!package.json
!package-lock.json
!eslint.config.ts
!vitest.config.ts

# Allow source directories
!packages/
!packages/**
!docs/
!docs/**
!examples/
!examples/**
!scripts/
!scripts/**
!tests/
!tests/**
!.github/
!.github/**

# Within allowed dirs, re-ignore all hidden directories then whitelist .svp/ and .github/
**/.*/
!**/.svp/
!**/.svp/**
!.github/
!.github/**

# Re-ignore generated/temp files within allowed dirs
tests/e2e/report-*
*.swp
*.kate-swp
*.swo
*~
