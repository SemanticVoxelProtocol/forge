{
  "round": 8,
  "description": "Order state machine",
  "setup": [
    {
      "name": "Create product for state machine tests",
      "method": "POST",
      "path": "/api/v1/products",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "body": {
        "name": "State Machine Widget",
        "description": "Product for order state tests",
        "priceCents": 5000,
        "category": "widgets"
      },
      "capture": {
        "smProductId": "data.id"
      }
    },
    {
      "name": "Set inventory on state machine product",
      "method": "PUT",
      "path": "/api/v1/products/$smProductId/inventory",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "body": {
        "stock": 100
      }
    },
    {
      "name": "Create order for shipping test (paid)",
      "method": "POST",
      "path": "/api/v1/orders",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $buyerToken"
      },
      "body": {
        "items": [
          { "productId": "$smProductId", "quantity": 1 }
        ]
      },
      "capture": {
        "smOrderShip": "data.id"
      }
    },
    {
      "name": "Pay order for shipping test",
      "method": "POST",
      "path": "/api/v1/orders/$smOrderShip/pay",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $buyerToken"
      },
      "body": {
        "paymentMethod": "card",
        "paymentToken": "tok_test_ship"
      }
    },
    {
      "name": "Create order for delivery test (paid)",
      "method": "POST",
      "path": "/api/v1/orders",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $buyerToken"
      },
      "body": {
        "items": [
          { "productId": "$smProductId", "quantity": 1 }
        ]
      },
      "capture": {
        "smOrderDeliver": "data.id"
      }
    },
    {
      "name": "Pay order for delivery test",
      "method": "POST",
      "path": "/api/v1/orders/$smOrderDeliver/pay",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $buyerToken"
      },
      "body": {
        "paymentMethod": "card",
        "paymentToken": "tok_test_deliver"
      }
    },
    {
      "name": "Ship order for delivery test",
      "method": "POST",
      "path": "/api/v1/orders/$smOrderDeliver/ship",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "body": {
        "trackingNumber": "TRACK-DELIVER-001"
      }
    },
    {
      "name": "Create order for cancellation test (pending_payment)",
      "method": "POST",
      "path": "/api/v1/orders",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $buyerToken"
      },
      "body": {
        "items": [
          { "productId": "$smProductId", "quantity": 2 }
        ]
      },
      "capture": {
        "smOrderCancel": "data.id"
      }
    },
    {
      "name": "Create paid order for cancel-paid test",
      "method": "POST",
      "path": "/api/v1/orders",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $buyerToken"
      },
      "body": {
        "items": [
          { "productId": "$smProductId", "quantity": 1 }
        ]
      },
      "capture": {
        "smOrderCancelPaid": "data.id"
      }
    },
    {
      "name": "Pay order for cancel-paid test",
      "method": "POST",
      "path": "/api/v1/orders/$smOrderCancelPaid/pay",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $buyerToken"
      },
      "body": {
        "paymentMethod": "card",
        "paymentToken": "tok_test_cancel_paid"
      }
    },
    {
      "name": "Create pending order for non-buyer cancel test",
      "method": "POST",
      "path": "/api/v1/orders",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $buyerToken"
      },
      "body": {
        "items": [
          { "productId": "$smProductId", "quantity": 1 }
        ]
      },
      "capture": {
        "smOrderCancelOther": "data.id"
      }
    },
    {
      "name": "Create pending order for buyer-ship test",
      "method": "POST",
      "path": "/api/v1/orders",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $buyerToken"
      },
      "body": {
        "items": [
          { "productId": "$smProductId", "quantity": 1 }
        ]
      },
      "capture": {
        "smOrderBuyerShip": "data.id"
      }
    },
    {
      "name": "Pay buyer-ship order",
      "method": "POST",
      "path": "/api/v1/orders/$smOrderBuyerShip/pay",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $buyerToken"
      },
      "body": {
        "paymentMethod": "card",
        "paymentToken": "tok_test_buyer_ship"
      }
    }
  ],
  "tests": [
    {
      "name": "Ship paid order as admin returns 200 with status shipped",
      "method": "POST",
      "path": "/api/v1/orders/$smOrderShip/ship",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "body": {
        "trackingNumber": "TRACK-001"
      },
      "expected": {
        "status": 200,
        "body": {
          "data.status": "shipped"
        }
      }
    },
    {
      "name": "Ship pending_payment order returns 409",
      "method": "POST",
      "path": "/api/v1/orders/$smOrderCancel/ship",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "body": {
        "trackingNumber": "TRACK-INVALID"
      },
      "expected": {
        "status": 409,
        "bodyHasFields": ["error"]
      }
    },
    {
      "name": "Ship already-shipped order returns 409",
      "method": "POST",
      "path": "/api/v1/orders/$smOrderShip/ship",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "body": {
        "trackingNumber": "TRACK-DUPE"
      },
      "expected": {
        "status": 409,
        "bodyHasFields": ["error"]
      }
    },
    {
      "name": "Deliver shipped order returns 200 with status delivered",
      "method": "POST",
      "path": "/api/v1/orders/$smOrderDeliver/deliver",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "expected": {
        "status": 200,
        "body": {
          "data.status": "delivered"
        }
      }
    },
    {
      "name": "Deliver non-shipped (paid) order returns 409",
      "method": "POST",
      "path": "/api/v1/orders/$smOrderCancelPaid/deliver",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "expected": {
        "status": 409,
        "bodyHasFields": ["error"]
      }
    },
    {
      "name": "Cancel pending_payment order by buyer returns 200 with status cancelled",
      "method": "POST",
      "path": "/api/v1/orders/$smOrderCancel/cancel",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $buyerToken"
      },
      "expected": {
        "status": 200,
        "body": {
          "data.status": "cancelled"
        }
      }
    },
    {
      "name": "Cancel paid order returns 409",
      "method": "POST",
      "path": "/api/v1/orders/$smOrderCancelPaid/cancel",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $buyerToken"
      },
      "expected": {
        "status": 409,
        "bodyHasFields": ["error"]
      }
    },
    {
      "name": "Cancel by non-buyer (seller) returns 403",
      "method": "POST",
      "path": "/api/v1/orders/$smOrderCancelOther/cancel",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $sellerToken"
      },
      "expected": {
        "status": 403,
        "bodyHasFields": ["error"]
      }
    },
    {
      "name": "Cancelled order restores inventory — check stock increased",
      "method": "GET",
      "path": "/api/v1/products/$smProductId/inventory",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "expected": {
        "status": 200,
        "bodyHasFields": ["data.stock"]
      }
    },
    {
      "name": "Ship by buyer returns 403",
      "method": "POST",
      "path": "/api/v1/orders/$smOrderBuyerShip/ship",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $buyerToken"
      },
      "body": {
        "trackingNumber": "TRACK-BUYER"
      },
      "expected": {
        "status": 403,
        "bodyHasFields": ["error"]
      }
    },
    {
      "name": "Deliver by buyer returns 403",
      "method": "POST",
      "path": "/api/v1/orders/$smOrderDeliver/deliver",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $buyerToken"
      },
      "expected": {
        "status": 403,
        "bodyHasFields": ["error"]
      }
    },
    {
      "name": "Shipped order detail shows status and timestamps",
      "method": "GET",
      "path": "/api/v1/orders/$smOrderShip",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "expected": {
        "status": 200,
        "body": {
          "data.status": "shipped"
        },
        "bodyHasFields": ["data.id", "data.status", "data.createdAt", "data.updatedAt"]
      }
    },
    {
      "name": "Delivered order detail shows correct status",
      "method": "GET",
      "path": "/api/v1/orders/$smOrderDeliver",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "expected": {
        "status": 200,
        "body": {
          "data.status": "delivered"
        },
        "bodyHasFields": ["data.id", "data.status", "data.createdAt", "data.updatedAt"]
      }
    },
    {
      "name": "Cancelled order detail shows correct status",
      "method": "GET",
      "path": "/api/v1/orders/$smOrderCancel",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "expected": {
        "status": 200,
        "body": {
          "data.status": "cancelled"
        }
      }
    },
    {
      "name": "Deliver already-delivered order returns 409",
      "method": "POST",
      "path": "/api/v1/orders/$smOrderDeliver/deliver",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "expected": {
        "status": 409,
        "bodyHasFields": ["error"]
      }
    }
  ]
}
