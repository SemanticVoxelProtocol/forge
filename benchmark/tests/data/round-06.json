{
  "round": 6,
  "description": "Inventory management",
  "setup": [
    {
      "name": "Create product for inventory tests",
      "method": "POST",
      "path": "/api/v1/products",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "body": {
        "name": "Inventory Widget",
        "description": "A widget for inventory testing",
        "priceCents": 2500,
        "category": "widgets"
      },
      "capture": {
        "invProductId": "data.id"
      }
    },
    {
      "name": "Create second product for multi-item tests",
      "method": "POST",
      "path": "/api/v1/products",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "body": {
        "name": "Inventory Gadget",
        "description": "A gadget for inventory testing",
        "priceCents": 4000,
        "category": "gadgets"
      },
      "capture": {
        "invProductId2": "data.id"
      }
    },
    {
      "name": "Create third product for depletion tests",
      "method": "POST",
      "path": "/api/v1/products",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "body": {
        "name": "Scarce Item",
        "description": "Limited stock item",
        "priceCents": 1500,
        "category": "widgets"
      },
      "capture": {
        "scarceProductId": "data.id"
      }
    }
  ],
  "tests": [
    {
      "name": "Set inventory stock to 200",
      "method": "PUT",
      "path": "/api/v1/products/$invProductId/inventory",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "body": {
        "stock": 200
      },
      "expected": {
        "status": 200,
        "body": {
          "data.stock": 200
        }
      }
    },
    {
      "name": "Get inventory returns correct stock number",
      "method": "GET",
      "path": "/api/v1/products/$invProductId/inventory",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "expected": {
        "status": 200,
        "body": {
          "data.stock": 200
        }
      }
    },
    {
      "name": "Product listing shows stock field",
      "method": "GET",
      "path": "/api/v1/products/$invProductId",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "expected": {
        "status": 200,
        "bodyHasFields": ["data.stock"]
      }
    },
    {
      "name": "Set second product stock to 50",
      "method": "PUT",
      "path": "/api/v1/products/$invProductId2/inventory",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "body": {
        "stock": 50
      },
      "expected": {
        "status": 200,
        "body": {
          "data.stock": 50
        }
      }
    },
    {
      "name": "Set scarce product stock to 1",
      "method": "PUT",
      "path": "/api/v1/products/$scarceProductId/inventory",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "body": {
        "stock": 1
      },
      "expected": {
        "status": 200,
        "body": {
          "data.stock": 1
        }
      }
    },
    {
      "name": "Create order when stock is sufficient returns 201 and decrements stock",
      "method": "POST",
      "path": "/api/v1/orders",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $buyerToken"
      },
      "body": {
        "items": [
          { "productId": "$invProductId", "quantity": 3 }
        ]
      },
      "expected": {
        "status": 201,
        "bodyHasFields": ["data.id", "data.items", "data.totalCents"]
      },
      "capture": {
        "invOrderId": "data.id"
      }
    },
    {
      "name": "Stock is decremented after successful order",
      "method": "GET",
      "path": "/api/v1/products/$invProductId/inventory",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "expected": {
        "status": 200,
        "body": {
          "data.stock": 197
        }
      }
    },
    {
      "name": "Order exact remaining stock depletes to 0",
      "method": "POST",
      "path": "/api/v1/orders",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $buyerToken"
      },
      "body": {
        "items": [
          { "productId": "$scarceProductId", "quantity": 1 }
        ]
      },
      "expected": {
        "status": 201,
        "bodyHasFields": ["data.id"]
      },
      "capture": {
        "depletionOrderId": "data.id"
      }
    },
    {
      "name": "Stock is 0 after exact depletion",
      "method": "GET",
      "path": "/api/v1/products/$scarceProductId/inventory",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "expected": {
        "status": 200,
        "body": {
          "data.stock": 0
        }
      }
    },
    {
      "name": "Create order when stock insufficient returns 400",
      "method": "POST",
      "path": "/api/v1/orders",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $buyerToken"
      },
      "body": {
        "items": [
          { "productId": "$scarceProductId", "quantity": 1 }
        ]
      },
      "expected": {
        "status": 400,
        "body": {
          "error.code": "insufficient_stock"
        }
      }
    },
    {
      "name": "Stock cannot go negative — large quantity on depleted product returns 400",
      "method": "POST",
      "path": "/api/v1/orders",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $buyerToken"
      },
      "body": {
        "items": [
          { "productId": "$scarceProductId", "quantity": 100 }
        ]
      },
      "expected": {
        "status": 400,
        "body": {
          "error.code": "insufficient_stock"
        }
      }
    },
    {
      "name": "Set stock to 0 explicitly, then try to order returns 400",
      "method": "PUT",
      "path": "/api/v1/products/$invProductId2/inventory",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "body": {
        "stock": 0
      },
      "expected": {
        "status": 200,
        "body": {
          "data.stock": 0
        }
      }
    },
    {
      "name": "Order zero-stock product returns 400",
      "method": "POST",
      "path": "/api/v1/orders",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $buyerToken"
      },
      "body": {
        "items": [
          { "productId": "$invProductId2", "quantity": 1 }
        ]
      },
      "expected": {
        "status": 400,
        "body": {
          "error.code": "insufficient_stock"
        }
      }
    },
    {
      "name": "Restock product for multi-item cart test",
      "method": "PUT",
      "path": "/api/v1/products/$invProductId2/inventory",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "body": {
        "stock": 10
      },
      "expected": {
        "status": 200,
        "body": {
          "data.stock": 10
        }
      }
    },
    {
      "name": "Multi-item cart with different stock levels succeeds",
      "method": "POST",
      "path": "/api/v1/orders",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $buyerToken"
      },
      "body": {
        "items": [
          { "productId": "$invProductId", "quantity": 2 },
          { "productId": "$invProductId2", "quantity": 5 }
        ]
      },
      "expected": {
        "status": 201,
        "bodyHasFields": ["data.id", "data.items", "data.totalCents"]
      }
    }
  ]
}
