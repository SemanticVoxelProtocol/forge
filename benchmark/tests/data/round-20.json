{
  "round": 20,
  "description": "API v2 with backward compatibility (v2 format, v1 compatibility, cross-version reads)",
  "setup": [
    {
      "name": "Ensure v1 product exists for cross-version read tests",
      "method": "GET",
      "path": "/api/v1/products/$productId",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "capture": {
        "v1ProductName": "data.name",
        "v1ProductPriceCents": "data.priceCents"
      }
    },
    {
      "name": "Ensure second v1 product exists",
      "method": "GET",
      "path": "/api/v1/products/$product2Id",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "capture": {
        "v1Product2Name": "data.name",
        "v1Product2PriceCents": "data.priceCents"
      }
    }
  ],
  "tests": [
    {
      "name": "POST /api/v2/products returns 201 with v2 format",
      "method": "POST",
      "path": "/api/v2/products",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "body": {
        "name": "V2 Smart Watch",
        "description": "Next-gen smartwatch with health monitoring",
        "pricing": {
          "baseCents": 29999,
          "currency": "USD"
        },
        "category": "electronics",
        "tags": ["wearable", "health", "smart"],
        "metadata": {
          "brand": "TechCo",
          "warrantyMonths": "24",
          "waterResistance": "5ATM"
        }
      },
      "expected": {
        "status": 201,
        "bodyHasFields": [
          "data.id",
          "data.name",
          "data.pricing",
          "data.pricing.baseCents",
          "data.pricing.currency",
          "data.tags",
          "data.metadata",
          "data.createdAt"
        ]
      },
      "capture": {
        "v2ProductId": "data.id"
      }
    },
    {
      "name": "v2 product has pricing object, tags array, metadata object",
      "method": "GET",
      "path": "/api/v2/products/$v2ProductId",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "expected": {
        "status": 200,
        "body": {
          "data.pricing.baseCents": 29999,
          "data.pricing.currency": "USD"
        },
        "bodyHasFields": [
          "data.pricing",
          "data.pricing.baseCents",
          "data.pricing.currency",
          "data.tags",
          "data.metadata"
        ]
      }
    },
    {
      "name": "v2 product tags and metadata persisted correctly",
      "method": "GET",
      "path": "/api/v2/products/$v2ProductId",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "expected": {
        "status": 200,
        "body": {
          "data.metadata.brand": "TechCo",
          "data.metadata.warrantyMonths": "24"
        }
      }
    },
    {
      "name": "GET /api/v2/products returns v2 format list",
      "method": "GET",
      "path": "/api/v2/products",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "expected": {
        "status": 200,
        "bodyHasFields": ["data.items", "data.total", "data.page", "data.pageSize"]
      }
    },
    {
      "name": "v1 GET /api/v1/products still returns old format (priceCents, no tags/metadata)",
      "method": "GET",
      "path": "/api/v1/products",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "expected": {
        "status": 200,
        "bodyHasFields": ["data.items", "data.total", "data.page", "data.pageSize"]
      }
    },
    {
      "name": "v1 GET /api/v1/products/:id returns old format",
      "method": "GET",
      "path": "/api/v1/products/$productId",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "expected": {
        "status": 200,
        "bodyHasFields": ["data.priceCents", "data.name", "data.category"],
        "bodyNotHasFields": ["data.pricing", "data.tags", "data.metadata"]
      }
    },
    {
      "name": "v1 POST /api/v1/products still works with old format",
      "method": "POST",
      "path": "/api/v1/products",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "body": {
        "name": "V1 Legacy Lamp",
        "description": "A lamp created via v1 API",
        "priceCents": 3500,
        "category": "home"
      },
      "expected": {
        "status": 201,
        "bodyHasFields": ["data.id", "data.priceCents"]
      },
      "capture": {
        "v1LegacyProductId": "data.id"
      }
    },
    {
      "name": "Product created via v2 readable via v1 (format converted)",
      "method": "GET",
      "path": "/api/v1/products/$v2ProductId",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "expected": {
        "status": 200,
        "body": {
          "data.priceCents": 29999
        },
        "bodyHasFields": ["data.priceCents", "data.name"],
        "bodyNotHasFields": ["data.pricing"]
      }
    },
    {
      "name": "Product created via v1 readable via v2 (defaults filled)",
      "method": "GET",
      "path": "/api/v2/products/$v1LegacyProductId",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "expected": {
        "status": 200,
        "body": {
          "data.pricing.baseCents": 3500
        },
        "bodyHasFields": [
          "data.pricing",
          "data.pricing.baseCents",
          "data.pricing.currency",
          "data.tags",
          "data.metadata"
        ]
      }
    },
    {
      "name": "v1 listing does not break with v2-created products",
      "method": "GET",
      "path": "/api/v1/products?page=1&pageSize=50",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "expected": {
        "status": 200,
        "bodyHasFields": ["data.items", "data.total"]
      }
    },
    {
      "name": "v2 listing includes v1-created products with defaults",
      "method": "GET",
      "path": "/api/v2/products?page=1&pageSize=50",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "expected": {
        "status": 200,
        "bodyHasFields": ["data.items", "data.total"]
      }
    },
    {
      "name": "v1 pagination still works",
      "method": "GET",
      "path": "/api/v1/products?page=1&pageSize=2",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "expected": {
        "status": 200,
        "bodyHasFields": ["data.items", "data.page", "data.pageSize", "data.total"]
      }
    },
    {
      "name": "v2 pagination works",
      "method": "GET",
      "path": "/api/v2/products?page=1&pageSize=2",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "expected": {
        "status": 200,
        "bodyHasFields": ["data.items", "data.page", "data.pageSize", "data.total"]
      }
    },
    {
      "name": "All other v1 endpoints (cart, orders, etc.) unaffected",
      "method": "GET",
      "path": "/api/v1/orders",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $buyerToken"
      },
      "expected": {
        "status": 200,
        "bodyHasFields": ["data.items"]
      }
    }
  ]
}
