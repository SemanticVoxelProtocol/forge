{
  "round": 4,
  "description": "Order creation and management",
  "setup": [
    {
      "name": "Clear cart before order setup",
      "method": "DELETE",
      "path": "/api/v1/cart",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $cartBuyerToken"
      }
    },
    {
      "name": "Add headphones to cart for order",
      "method": "POST",
      "path": "/api/v1/cart/items",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $cartBuyerToken"
      },
      "body": {
        "productId": "$productId",
        "quantity": 2
      }
    },
    {
      "name": "Add coffee beans to cart for order",
      "method": "POST",
      "path": "/api/v1/cart/items",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $cartBuyerToken"
      },
      "body": {
        "productId": "$product2Id",
        "quantity": 1
      },
      "capture": {
        "preOrderCartTotal": "data.totalCents"
      }
    }
  ],
  "tests": [
    {
      "name": "Create order from cart returns 201 with order data",
      "method": "POST",
      "path": "/api/v1/orders",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $cartBuyerToken"
      },
      "body": {},
      "expected": {
        "status": 201,
        "bodyHasFields": ["data.id", "data.items", "data.totalCents", "data.status", "data.createdAt"]
      },
      "capture": {
        "orderId": "data.id",
        "orderTotal": "data.totalCents"
      }
    },
    {
      "name": "Order has items snapshot with productName priceCents and quantity",
      "method": "GET",
      "path": "/api/v1/orders/$orderId",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $cartBuyerToken"
      },
      "expected": {
        "status": 200,
        "bodyHasFields": [
          "data.items[0].productName",
          "data.items[0].priceCents",
          "data.items[0].quantity"
        ]
      }
    },
    {
      "name": "Order totalCents matches cart totalCents",
      "method": "GET",
      "path": "/api/v1/orders/$orderId",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $cartBuyerToken"
      },
      "expected": {
        "status": 200,
        "body": {
          "data.totalCents": 28493
        }
      }
    },
    {
      "name": "Order status is pending_payment",
      "method": "GET",
      "path": "/api/v1/orders/$orderId",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $cartBuyerToken"
      },
      "expected": {
        "status": 200,
        "body": {
          "data.status": "pending_payment"
        }
      }
    },
    {
      "name": "Cart is empty after order creation",
      "method": "GET",
      "path": "/api/v1/cart",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $cartBuyerToken"
      },
      "expected": {
        "status": 200,
        "body": {
          "data.items": [],
          "data.totalCents": 0
        }
      }
    },
    {
      "name": "Create order with empty cart returns 400",
      "method": "POST",
      "path": "/api/v1/orders",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $cartBuyerToken"
      },
      "body": {},
      "expected": {
        "status": 400,
        "bodyHasFields": ["error"]
      }
    },
    {
      "name": "List orders includes the new order",
      "method": "GET",
      "path": "/api/v1/orders",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $cartBuyerToken"
      },
      "expected": {
        "status": 200,
        "bodyHasFields": ["data.items", "data.total"]
      }
    },
    {
      "name": "Get order by ID returns 200 with full details",
      "method": "GET",
      "path": "/api/v1/orders/$orderId",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $cartBuyerToken"
      },
      "expected": {
        "status": 200,
        "bodyHasFields": [
          "data.id",
          "data.items",
          "data.totalCents",
          "data.status",
          "data.createdAt"
        ]
      }
    },
    {
      "name": "Get non-existent order returns 404",
      "method": "GET",
      "path": "/api/v1/orders/00000000-0000-0000-0000-000000000000",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $cartBuyerToken"
      },
      "expected": {
        "status": 404,
        "bodyHasFields": ["error"]
      }
    },
    {
      "name": "Order items are snapshots (update product then verify order unchanged)",
      "method": "PUT",
      "path": "/api/v1/products/$productId",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "body": {
        "name": "Ultra Premium Wireless Headphones",
        "priceCents": 19999
      },
      "expected": {
        "status": 200,
        "body": {
          "data.priceCents": 19999
        }
      }
    },
    {
      "name": "Order still has original product name and price after product update",
      "method": "GET",
      "path": "/api/v1/orders/$orderId",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $cartBuyerToken"
      },
      "expected": {
        "status": 200,
        "body": {
          "data.totalCents": 28493
        }
      }
    },
    {
      "name": "Order list without auth returns 401",
      "method": "GET",
      "path": "/api/v1/orders",
      "headers": {
        "X-Tenant-ID": "$tenantId"
      },
      "expected": {
        "status": 401,
        "bodyHasFields": ["error"]
      }
    }
  ]
}
