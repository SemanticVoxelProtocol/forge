{
  "round": 19,
  "description": "Multi-currency support (exchange rates, conversion, tenant currency settings)",
  "setup": [
    {
      "name": "Create second tenant for currency tests",
      "method": "POST",
      "path": "/api/v1/tenants",
      "body": {
        "name": "Euro Store",
        "slug": "euro-store"
      },
      "capture": {
        "eurTenantId": "data.id"
      }
    },
    {
      "name": "Register admin on Euro tenant",
      "method": "POST",
      "path": "/api/v1/auth/register",
      "headers": {
        "X-Tenant-ID": "$eurTenantId"
      },
      "body": {
        "email": "admin@euro-store.com",
        "password": "Eur0Adm!n@Pass",
        "name": "Eva Euro Admin"
      },
      "capture": {
        "eurAdminToken": "data.token"
      }
    },
    {
      "name": "Register buyer on Euro tenant",
      "method": "POST",
      "path": "/api/v1/auth/register",
      "headers": {
        "X-Tenant-ID": "$eurTenantId"
      },
      "body": {
        "email": "buyer@euro-store.com",
        "password": "EurBuy3r@Pass!",
        "name": "Fritz Buyer"
      },
      "capture": {
        "eurBuyerToken": "data.token"
      }
    },
    {
      "name": "Create product on USD tenant for cross-currency reference",
      "method": "POST",
      "path": "/api/v1/products",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "body": {
        "name": "Currency Test Widget",
        "description": "Widget for multi-currency tests",
        "priceCents": 10000,
        "category": "electronics"
      },
      "capture": {
        "currencyProductId": "data.id"
      }
    },
    {
      "name": "Set stock on currency test product",
      "method": "PUT",
      "path": "/api/v1/products/$currencyProductId/inventory",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "body": {
        "stock": 50
      },
      "capture": {}
    }
  ],
  "tests": [
    {
      "name": "Set tenant currency to EUR returns 200",
      "method": "PUT",
      "path": "/api/v1/tenants/$eurTenantId/currency",
      "headers": {
        "X-Tenant-ID": "$eurTenantId",
        "Authorization": "Bearer $eurAdminToken"
      },
      "body": {
        "currency": "EUR"
      },
      "expected": {
        "status": 200,
        "body": {
          "data.currency": "EUR"
        }
      }
    },
    {
      "name": "GET exchange-rates returns rates object",
      "method": "GET",
      "path": "/api/v1/exchange-rates",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "expected": {
        "status": 200,
        "bodyHasFields": ["data.USD", "data.EUR", "data.CNY", "data.JPY", "data.GBP"]
      }
    },
    {
      "name": "Product created on EUR tenant shows currency field",
      "method": "POST",
      "path": "/api/v1/products",
      "headers": {
        "X-Tenant-ID": "$eurTenantId",
        "Authorization": "Bearer $eurAdminToken"
      },
      "body": {
        "name": "European Gadget",
        "description": "A gadget priced in EUR",
        "priceCents": 5000,
        "category": "electronics"
      },
      "expected": {
        "status": 201,
        "body": {
          "data.currency": "EUR"
        },
        "bodyHasFields": ["data.id", "data.priceCents", "data.currency"]
      },
      "capture": {
        "eurProductId": "data.id"
      }
    },
    {
      "name": "Set stock on EUR product",
      "method": "PUT",
      "path": "/api/v1/products/$eurProductId/inventory",
      "headers": {
        "X-Tenant-ID": "$eurTenantId",
        "Authorization": "Bearer $eurAdminToken"
      },
      "body": {
        "stock": 30
      },
      "expected": {
        "status": 200
      }
    },
    {
      "name": "Create order on EUR tenant records exchangeRate",
      "method": "POST",
      "path": "/api/v1/orders",
      "headers": {
        "X-Tenant-ID": "$eurTenantId",
        "Authorization": "Bearer $eurBuyerToken"
      },
      "body": {
        "items": [
          { "productId": "$eurProductId", "quantity": 1 }
        ]
      },
      "expected": {
        "status": 201,
        "bodyHasFields": ["data.id", "data.totalCents", "data.currency", "data.exchangeRate"]
      },
      "capture": {
        "eurOrderId": "data.id"
      }
    },
    {
      "name": "GET /products shows original currency on EUR tenant",
      "method": "GET",
      "path": "/api/v1/products/$eurProductId",
      "headers": {
        "X-Tenant-ID": "$eurTenantId",
        "Authorization": "Bearer $eurBuyerToken"
      },
      "expected": {
        "status": 200,
        "body": {
          "data.currency": "EUR"
        }
      }
    },
    {
      "name": "Historical orders unaffected by currency change — check original order on USD tenant",
      "method": "GET",
      "path": "/api/v1/orders/$dashOrderAId",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $buyerToken"
      },
      "expected": {
        "status": 200,
        "bodyHasFields": ["data.totalCents"]
      },
      "_comment": "totalCents should remain the same value as when it was created in USD"
    },
    {
      "name": "Set currency to invalid code returns 400",
      "method": "PUT",
      "path": "/api/v1/tenants/$eurTenantId/currency",
      "headers": {
        "X-Tenant-ID": "$eurTenantId",
        "Authorization": "Bearer $eurAdminToken"
      },
      "body": {
        "currency": "INVALID"
      },
      "expected": {
        "status": 400,
        "bodyHasFields": ["error"]
      }
    },
    {
      "name": "Set second tenant currency to JPY for conversion test",
      "method": "PUT",
      "path": "/api/v1/tenants/$eurTenantId/currency",
      "headers": {
        "X-Tenant-ID": "$eurTenantId",
        "Authorization": "Bearer $eurAdminToken"
      },
      "body": {
        "currency": "JPY"
      },
      "expected": {
        "status": 200,
        "body": {
          "data.currency": "JPY"
        }
      }
    },
    {
      "name": "Different tenant currencies produce correct conversions",
      "method": "POST",
      "path": "/api/v1/products",
      "headers": {
        "X-Tenant-ID": "$eurTenantId",
        "Authorization": "Bearer $eurAdminToken"
      },
      "body": {
        "name": "JPY Priced Item",
        "description": "Item with JPY currency",
        "priceCents": 150000,
        "category": "electronics"
      },
      "expected": {
        "status": 201,
        "body": {
          "data.currency": "JPY"
        },
        "bodyHasFields": ["data.priceCents", "data.currency"]
      }
    },
    {
      "name": "Conversion formula correct: targetCents = sourceCents / sourceRate * targetRate",
      "method": "GET",
      "path": "/api/v1/exchange-rates",
      "headers": {
        "X-Tenant-ID": "$eurTenantId",
        "Authorization": "Bearer $eurAdminToken"
      },
      "expected": {
        "status": 200,
        "bodyHasFields": ["data.USD", "data.EUR", "data.CNY", "data.JPY", "data.GBP"]
      },
      "_comment": "Verify rate values exist so conversion formula targetCents = sourceCents / sourceRate * targetRate can be validated"
    },
    {
      "name": "Set EUR tenant back to EUR for consistency",
      "method": "PUT",
      "path": "/api/v1/tenants/$eurTenantId/currency",
      "headers": {
        "X-Tenant-ID": "$eurTenantId",
        "Authorization": "Bearer $eurAdminToken"
      },
      "body": {
        "currency": "EUR"
      },
      "expected": {
        "status": 200,
        "body": {
          "data.currency": "EUR"
        }
      }
    }
  ]
}
