{
  "round": 16,
  "description": "Review system (ratings, moderation, seller replies)",
  "setup": [
    {
      "name": "Set stock on product for review order",
      "method": "PUT",
      "path": "/api/v1/products/$productId/inventory",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "body": {
        "stock": 100
      },
      "capture": {}
    },
    {
      "name": "Buyer creates order for review product",
      "method": "POST",
      "path": "/api/v1/orders",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $buyerToken"
      },
      "body": {
        "items": [
          { "productId": "$productId", "quantity": 1 }
        ]
      },
      "capture": {
        "reviewOrderId": "data.id"
      }
    },
    {
      "name": "Pay for order",
      "method": "POST",
      "path": "/api/v1/orders/$reviewOrderId/pay",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $buyerToken"
      },
      "body": {
        "paymentMethod": "card",
        "paymentToken": "tok_visa_success"
      },
      "capture": {}
    },
    {
      "name": "Ship order",
      "method": "POST",
      "path": "/api/v1/orders/$reviewOrderId/ship",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "body": {
        "trackingNumber": "TRACK-REVIEW-001"
      },
      "capture": {}
    },
    {
      "name": "Deliver order",
      "method": "POST",
      "path": "/api/v1/orders/$reviewOrderId/deliver",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "body": {},
      "capture": {}
    },
    {
      "name": "Register a non-buyer user for review permission tests",
      "method": "POST",
      "path": "/api/v1/auth/register",
      "headers": {
        "X-Tenant-ID": "$tenantId"
      },
      "body": {
        "email": "nonbuyer@bench-store.com",
        "password": "N0nBuy3r@Pass!",
        "name": "Nancy NonBuyer"
      },
      "capture": {
        "nonBuyerToken": "data.token"
      }
    },
    {
      "name": "Register seller user for review tests",
      "method": "POST",
      "path": "/api/v1/auth/register",
      "headers": {
        "X-Tenant-ID": "$tenantId"
      },
      "body": {
        "email": "seller-review@bench-store.com",
        "password": "S3ll3r@Pass!",
        "name": "Sam Seller"
      },
      "capture": {
        "sellerReviewToken": "data.token"
      }
    },
    {
      "name": "Promote seller user to seller role",
      "method": "PUT",
      "path": "/api/v1/users/$sellerReviewToken/role",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "body": {
        "role": "seller"
      },
      "capture": {}
    }
  ],
  "tests": [
    {
      "name": "Buyer who purchased creates review returns 201",
      "method": "POST",
      "path": "/api/v1/products/$productId/reviews",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $buyerToken"
      },
      "body": {
        "rating": 5,
        "comment": "Excellent noise cancellation and battery life!"
      },
      "expected": {
        "status": 201,
        "bodyHasFields": ["data.id", "data.rating", "data.comment", "data.status", "data.createdAt"]
      },
      "capture": {
        "reviewId": "data.id"
      }
    },
    {
      "name": "Review has rating 1-5, comment, and status pending",
      "method": "GET",
      "path": "/api/v1/reviews/$reviewId",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $buyerToken"
      },
      "expected": {
        "status": 200,
        "body": {
          "data.rating": 5,
          "data.comment": "Excellent noise cancellation and battery life!",
          "data.status": "pending"
        }
      }
    },
    {
      "name": "Non-buyer cannot create review returns 403",
      "method": "POST",
      "path": "/api/v1/products/$productId/reviews",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $nonBuyerToken"
      },
      "body": {
        "rating": 4,
        "comment": "I never bought this but want to review it"
      },
      "expected": {
        "status": 403,
        "bodyHasFields": ["error"]
      }
    },
    {
      "name": "Duplicate review same product same buyer returns 409",
      "method": "POST",
      "path": "/api/v1/products/$productId/reviews",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $buyerToken"
      },
      "body": {
        "rating": 3,
        "comment": "Trying to leave a second review"
      },
      "expected": {
        "status": 409,
        "bodyHasFields": ["error"]
      }
    },
    {
      "name": "Rating below 1 returns 400",
      "method": "POST",
      "path": "/api/v1/products/$product2Id/reviews",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $buyerToken"
      },
      "body": {
        "rating": 0,
        "comment": "Invalid rating"
      },
      "expected": {
        "status": 400,
        "bodyHasFields": ["error"]
      }
    },
    {
      "name": "Rating above 5 returns 400",
      "method": "POST",
      "path": "/api/v1/products/$product2Id/reviews",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $buyerToken"
      },
      "body": {
        "rating": 6,
        "comment": "Invalid rating too high"
      },
      "expected": {
        "status": 400,
        "bodyHasFields": ["error"]
      }
    },
    {
      "name": "Seller (non-buyer) cannot create review returns 403",
      "method": "POST",
      "path": "/api/v1/products/$productId/reviews",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $sellerReviewToken"
      },
      "body": {
        "rating": 4,
        "comment": "Seller trying to review own product"
      },
      "expected": {
        "status": 403,
        "bodyHasFields": ["error"]
      }
    },
    {
      "name": "Seller replies to review returns 200",
      "method": "POST",
      "path": "/api/v1/reviews/$reviewId/reply",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "body": {
        "comment": "Thank you for the kind review! We appreciate your feedback."
      },
      "expected": {
        "status": 200,
        "bodyHasFields": ["data.reply", "data.repliedAt"]
      }
    },
    {
      "name": "Admin moderates review: approve returns 200",
      "method": "PUT",
      "path": "/api/v1/reviews/$reviewId/moderate",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "body": {
        "status": "approved"
      },
      "expected": {
        "status": 200,
        "body": {
          "data.status": "approved"
        }
      }
    },
    {
      "name": "GET product reviews includes averageRating and reviewCount",
      "method": "GET",
      "path": "/api/v1/products/$productId/reviews",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $buyerToken"
      },
      "expected": {
        "status": 200,
        "bodyHasFields": ["data.items", "data.averageRating", "data.reviewCount", "data.page", "data.pageSize"]
      }
    },
    {
      "name": "averageRating only counts approved reviews",
      "method": "GET",
      "path": "/api/v1/products/$productId/reviews",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $buyerToken"
      },
      "expected": {
        "status": 200,
        "body": {
          "data.averageRating": 5,
          "data.reviewCount": 1
        }
      }
    },
    {
      "name": "Buyer sees approved reviews and own pending reviews",
      "method": "GET",
      "path": "/api/v1/products/$productId/reviews",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $buyerToken"
      },
      "expected": {
        "status": 200,
        "bodyHasFields": ["data.items"]
      }
    },
    {
      "name": "Admin sees all reviews regardless of status",
      "method": "GET",
      "path": "/api/v1/products/$productId/reviews?includeAll=true",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "expected": {
        "status": 200,
        "bodyHasFields": ["data.items", "data.total"]
      }
    },
    {
      "name": "Product listing includes averageRating field",
      "method": "GET",
      "path": "/api/v1/products/$productId",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $buyerToken"
      },
      "expected": {
        "status": 200,
        "bodyHasFields": ["data.averageRating"]
      }
    },
    {
      "name": "Reviews support pagination",
      "method": "GET",
      "path": "/api/v1/products/$productId/reviews?page=1&pageSize=1",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $buyerToken"
      },
      "expected": {
        "status": 200,
        "bodyHasFields": ["data.items", "data.page", "data.pageSize", "data.total"]
      }
    },
    {
      "name": "Admin moderates review: reject returns 200",
      "method": "PUT",
      "path": "/api/v1/reviews/$reviewId/moderate",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "body": {
        "status": "rejected",
        "reason": "Flagged for re-evaluation"
      },
      "expected": {
        "status": 200,
        "body": {
          "data.status": "rejected"
        }
      }
    }
  ]
}
