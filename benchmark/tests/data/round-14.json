{
  "round": 14,
  "description": "Bulk operations",
  "setup": [
    {
      "name": "Prepare a product for bulk update testing",
      "method": "POST",
      "path": "/api/v1/products",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $sellerToken"
      },
      "body": {
        "name": "Bulk Seed Alpha",
        "description": "Pre-existing product for bulk update",
        "priceCents": 1000,
        "stock": 10,
        "category": "accessories"
      },
      "capture": {
        "bulkSeedProductId": "data.id"
      }
    }
  ],
  "tests": [
    {
      "name": "Bulk create 5 products → all created",
      "method": "POST",
      "path": "/api/v1/products/bulk",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $sellerToken"
      },
      "body": {
        "products": [
          {
            "name": "Bulk Item 1",
            "description": "First bulk product",
            "priceCents": 1100,
            "stock": 15,
            "category": "electronics"
          },
          {
            "name": "Bulk Item 2",
            "description": "Second bulk product",
            "priceCents": 2200,
            "stock": 25,
            "category": "clothing"
          },
          {
            "name": "Bulk Item 3",
            "description": "Third bulk product",
            "priceCents": 3300,
            "stock": 35,
            "category": "accessories"
          },
          {
            "name": "Bulk Item 4",
            "description": "Fourth bulk product",
            "priceCents": 4400,
            "stock": 45,
            "category": "electronics"
          },
          {
            "name": "Bulk Item 5",
            "description": "Fifth bulk product",
            "priceCents": 5500,
            "stock": 55,
            "category": "home"
          }
        ]
      },
      "expected": {
        "status": 200,
        "bodyHasFields": ["data.created"],
        "bodyArrayLength": {
          "path": "data.created",
          "length": 5
        }
      },
      "capture": {
        "bulkProduct1Id": "data.created[0].id",
        "bulkProduct2Id": "data.created[1].id"
      }
    },
    {
      "name": "Bulk create with 1 invalid + 4 valid → partial success",
      "method": "POST",
      "path": "/api/v1/products/bulk",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $sellerToken"
      },
      "body": {
        "products": [
          {
            "name": "Valid Bulk A",
            "description": "Valid product",
            "priceCents": 999,
            "stock": 10,
            "category": "electronics"
          },
          {
            "name": "",
            "description": "Invalid: empty name",
            "priceCents": 500,
            "stock": 5,
            "category": "clothing"
          },
          {
            "name": "Valid Bulk B",
            "description": "Valid product",
            "priceCents": 1500,
            "stock": 20,
            "category": "accessories"
          },
          {
            "name": "Valid Bulk C",
            "description": "Valid product",
            "priceCents": 2000,
            "stock": 30,
            "category": "home"
          },
          {
            "name": "Valid Bulk D",
            "description": "Valid product",
            "priceCents": 2500,
            "stock": 40,
            "category": "electronics"
          }
        ]
      },
      "expected": {
        "status": 200,
        "bodyHasFields": ["data.created", "data.errors"],
        "bodyArrayLength": {
          "path": "data.created",
          "length": 4
        },
        "bodyArrayMinLength": {
          "path": "data.errors",
          "min": 1
        }
      }
    },
    {
      "name": "Bulk create exceeding 100 items → 400",
      "method": "POST",
      "path": "/api/v1/products/bulk",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $sellerToken"
      },
      "body": {
        "products": "__GENERATE_ARRAY_101_ITEMS__"
      },
      "bodyNote": "Test runner should generate array of 101 minimal product objects",
      "expected": {
        "status": 400,
        "bodyHasFields": ["error"]
      }
    },
    {
      "name": "Bulk create as buyer → 403",
      "method": "POST",
      "path": "/api/v1/products/bulk",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $buyerToken"
      },
      "body": {
        "products": [
          {
            "name": "Buyer Bulk Attempt",
            "description": "Should be rejected",
            "priceCents": 100,
            "stock": 1,
            "category": "electronics"
          }
        ]
      },
      "expected": {
        "status": 403,
        "bodyHasFields": ["error"]
      }
    },
    {
      "name": "Bulk update prices → all updated",
      "method": "PUT",
      "path": "/api/v1/products/bulk",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $sellerToken"
      },
      "body": {
        "updates": [
          {
            "id": "$bulkProduct1Id",
            "priceCents": 1199
          },
          {
            "id": "$bulkProduct2Id",
            "priceCents": 2399
          },
          {
            "id": "$bulkSeedProductId",
            "priceCents": 1099
          }
        ]
      },
      "expected": {
        "status": 200,
        "bodyHasFields": ["data.updated"],
        "bodyArrayLength": {
          "path": "data.updated",
          "length": 3
        }
      }
    },
    {
      "name": "Bulk update with non-existent ID → partial success",
      "method": "PUT",
      "path": "/api/v1/products/bulk",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $sellerToken"
      },
      "body": {
        "updates": [
          {
            "id": "$bulkProduct1Id",
            "priceCents": 1250
          },
          {
            "id": "00000000-0000-0000-0000-000000000000",
            "priceCents": 9999
          }
        ]
      },
      "expected": {
        "status": 200,
        "bodyHasFields": ["data.updated", "data.errors"],
        "bodyArrayLength": {
          "path": "data.updated",
          "length": 1
        },
        "bodyArrayMinLength": {
          "path": "data.errors",
          "min": 1
        }
      }
    },
    {
      "name": "Seller can only bulk-create own products (not impersonate)",
      "method": "POST",
      "path": "/api/v1/products/bulk",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $sellerToken"
      },
      "body": {
        "products": [
          {
            "name": "Seller Owned Bulk",
            "description": "Created by seller",
            "priceCents": 700,
            "stock": 10,
            "category": "accessories"
          }
        ]
      },
      "expected": {
        "status": 200,
        "bodyHasFields": ["data.created"],
        "bodyArrayLength": {
          "path": "data.created",
          "length": 1
        }
      }
    },
    {
      "name": "Bulk create response has created and errors arrays",
      "method": "POST",
      "path": "/api/v1/products/bulk",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $sellerToken"
      },
      "body": {
        "products": [
          {
            "name": "Shape Check Product",
            "description": "Verify response shape",
            "priceCents": 800,
            "stock": 5,
            "category": "electronics"
          }
        ]
      },
      "expected": {
        "status": 200,
        "bodyHasFields": ["data.created", "data.errors"]
      }
    },
    {
      "name": "Bulk update response has updated and errors arrays",
      "method": "PUT",
      "path": "/api/v1/products/bulk",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $sellerToken"
      },
      "body": {
        "updates": [
          {
            "id": "$bulkProduct1Id",
            "stock": 99
          }
        ]
      },
      "expected": {
        "status": 200,
        "bodyHasFields": ["data.updated", "data.errors"]
      }
    },
    {
      "name": "Bulk-created products appear in normal GET /products listing",
      "method": "GET",
      "path": "/api/v1/products",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $buyerToken"
      },
      "expected": {
        "status": 200,
        "bodyArrayContains": {
          "path": "data",
          "field": "id",
          "value": "$bulkProduct1Id"
        }
      }
    },
    {
      "name": "Bulk update with invalid price (0) → error for that item",
      "method": "PUT",
      "path": "/api/v1/products/bulk",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $sellerToken"
      },
      "body": {
        "updates": [
          {
            "id": "$bulkProduct1Id",
            "priceCents": 0
          },
          {
            "id": "$bulkProduct2Id",
            "priceCents": 3000
          }
        ]
      },
      "expected": {
        "status": 200,
        "bodyHasFields": ["data.updated", "data.errors"],
        "bodyArrayLength": {
          "path": "data.updated",
          "length": 1
        },
        "bodyArrayMinLength": {
          "path": "data.errors",
          "min": 1
        }
      }
    },
    {
      "name": "Bulk update with negative price → error for that item",
      "method": "PUT",
      "path": "/api/v1/products/bulk",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $sellerToken"
      },
      "body": {
        "updates": [
          {
            "id": "$bulkProduct2Id",
            "priceCents": -500
          }
        ]
      },
      "expected": {
        "status": 200,
        "bodyHasFields": ["data.errors"],
        "bodyArrayMinLength": {
          "path": "data.errors",
          "min": 1
        }
      }
    }
  ]
}
