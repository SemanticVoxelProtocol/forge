{
  "round": 5,
  "description": "Payment processing and webhook handling",
  "setup": [
    {
      "name": "Add product to cart for payment order",
      "method": "POST",
      "path": "/api/v1/cart/items",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $cartBuyerToken"
      },
      "body": {
        "productId": "$product4Id",
        "quantity": 1
      }
    },
    {
      "name": "Add second product to cart for payment order",
      "method": "POST",
      "path": "/api/v1/cart/items",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $cartBuyerToken"
      },
      "body": {
        "productId": "$product5Id",
        "quantity": 1
      }
    },
    {
      "name": "Create order for payment tests",
      "method": "POST",
      "path": "/api/v1/orders",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $cartBuyerToken"
      },
      "body": {},
      "capture": {
        "payOrderId": "data.id",
        "payOrderTotal": "data.totalCents"
      }
    },
    {
      "name": "Add product to cart for retry payment order",
      "method": "POST",
      "path": "/api/v1/cart/items",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $cartBuyerToken"
      },
      "body": {
        "productId": "$product2Id",
        "quantity": 3
      }
    },
    {
      "name": "Create second order for retry payment tests",
      "method": "POST",
      "path": "/api/v1/orders",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $cartBuyerToken"
      },
      "body": {},
      "capture": {
        "retryOrderId": "data.id"
      }
    }
  ],
  "tests": [
    {
      "name": "Pay for order returns 200 with paymentId",
      "method": "POST",
      "path": "/api/v1/orders/$payOrderId/pay",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $cartBuyerToken"
      },
      "body": {
        "method": "credit_card"
      },
      "expected": {
        "status": 200,
        "bodyHasFields": ["data.paymentId", "data.status"]
      },
      "capture": {
        "paymentId": "data.paymentId"
      }
    },
    {
      "name": "Pay for non-existent order returns 404",
      "method": "POST",
      "path": "/api/v1/orders/00000000-0000-0000-0000-000000000000/pay",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $cartBuyerToken"
      },
      "body": {
        "method": "credit_card"
      },
      "expected": {
        "status": 404,
        "bodyHasFields": ["error"]
      }
    },
    {
      "name": "Pay for already-paid order returns 409",
      "method": "POST",
      "path": "/api/v1/orders/$payOrderId/pay",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $cartBuyerToken"
      },
      "body": {
        "method": "credit_card"
      },
      "expected": {
        "status": 409,
        "bodyHasFields": ["error"]
      }
    },
    {
      "name": "Webhook success callback returns 200 and order becomes paid",
      "method": "POST",
      "path": "/api/v1/payments/webhook",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Content-Type": "application/json"
      },
      "body": {
        "paymentId": "$paymentId",
        "status": "success",
        "processedAt": "2026-03-21T10:30:00Z"
      },
      "expected": {
        "status": 200
      }
    },
    {
      "name": "Order status is paid after successful webhook",
      "method": "GET",
      "path": "/api/v1/orders/$payOrderId",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $cartBuyerToken"
      },
      "expected": {
        "status": 200,
        "body": {
          "data.status": "paid"
        }
      }
    },
    {
      "name": "Webhook with same paymentId again is idempotent",
      "method": "POST",
      "path": "/api/v1/payments/webhook",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Content-Type": "application/json"
      },
      "body": {
        "paymentId": "$paymentId",
        "status": "success",
        "processedAt": "2026-03-21T10:31:00Z"
      },
      "expected": {
        "status": 200
      }
    },
    {
      "name": "Pay for retry order to get paymentId",
      "method": "POST",
      "path": "/api/v1/orders/$retryOrderId/pay",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $cartBuyerToken"
      },
      "body": {
        "method": "credit_card"
      },
      "expected": {
        "status": 200,
        "bodyHasFields": ["data.paymentId"]
      },
      "capture": {
        "retryPaymentId": "data.paymentId"
      }
    },
    {
      "name": "Webhook failure callback keeps order pending_payment",
      "method": "POST",
      "path": "/api/v1/payments/webhook",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Content-Type": "application/json"
      },
      "body": {
        "paymentId": "$retryPaymentId",
        "status": "failed",
        "reason": "insufficient_funds",
        "processedAt": "2026-03-21T11:00:00Z"
      },
      "expected": {
        "status": 200
      }
    },
    {
      "name": "Order stays pending_payment after failed webhook",
      "method": "GET",
      "path": "/api/v1/orders/$retryOrderId",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $cartBuyerToken"
      },
      "expected": {
        "status": 200,
        "body": {
          "data.status": "pending_payment"
        }
      }
    },
    {
      "name": "Pay for order after failed payment succeeds (retry allowed)",
      "method": "POST",
      "path": "/api/v1/orders/$retryOrderId/pay",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $cartBuyerToken"
      },
      "body": {
        "method": "credit_card"
      },
      "expected": {
        "status": 200,
        "bodyHasFields": ["data.paymentId"]
      },
      "capture": {
        "retryPaymentId2": "data.paymentId"
      }
    },
    {
      "name": "Webhook success after retry makes order paid",
      "method": "POST",
      "path": "/api/v1/payments/webhook",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Content-Type": "application/json"
      },
      "body": {
        "paymentId": "$retryPaymentId2",
        "status": "success",
        "processedAt": "2026-03-21T11:05:00Z"
      },
      "expected": {
        "status": 200
      }
    },
    {
      "name": "Get order shows paid status after retry success",
      "method": "GET",
      "path": "/api/v1/orders/$retryOrderId",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $cartBuyerToken"
      },
      "expected": {
        "status": 200,
        "body": {
          "data.status": "paid"
        }
      }
    }
  ]
}
