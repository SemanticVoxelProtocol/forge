{
  "round": 17,
  "description": "Seller dashboard analytics (sales, top products, return rate)",
  "setup": [
    {
      "name": "Set stock on product for dashboard order",
      "method": "PUT",
      "path": "/api/v1/products/$productId/inventory",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "body": {
        "stock": 200
      },
      "capture": {}
    },
    {
      "name": "Set stock on second product for dashboard",
      "method": "PUT",
      "path": "/api/v1/products/$product2Id/inventory",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "body": {
        "stock": 100
      },
      "capture": {}
    },
    {
      "name": "Buyer creates order A (2x product1) for dashboard data",
      "method": "POST",
      "path": "/api/v1/orders",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $buyerToken"
      },
      "body": {
        "items": [
          { "productId": "$productId", "quantity": 2 }
        ]
      },
      "capture": {
        "dashOrderAId": "data.id"
      }
    },
    {
      "name": "Pay for order A",
      "method": "POST",
      "path": "/api/v1/orders/$dashOrderAId/pay",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $buyerToken"
      },
      "body": {
        "paymentMethod": "card",
        "paymentToken": "tok_visa_success"
      },
      "capture": {}
    },
    {
      "name": "Deliver order A",
      "method": "POST",
      "path": "/api/v1/orders/$dashOrderAId/ship",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "body": {
        "trackingNumber": "TRACK-DASH-A"
      },
      "capture": {}
    },
    {
      "name": "Complete delivery order A",
      "method": "POST",
      "path": "/api/v1/orders/$dashOrderAId/deliver",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "body": {},
      "capture": {}
    },
    {
      "name": "Buyer creates order B (3x product2) for dashboard data",
      "method": "POST",
      "path": "/api/v1/orders",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $buyerToken"
      },
      "body": {
        "items": [
          { "productId": "$product2Id", "quantity": 3 }
        ]
      },
      "capture": {
        "dashOrderBId": "data.id"
      }
    },
    {
      "name": "Pay for order B",
      "method": "POST",
      "path": "/api/v1/orders/$dashOrderBId/pay",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $buyerToken"
      },
      "body": {
        "paymentMethod": "card",
        "paymentToken": "tok_visa_success"
      },
      "capture": {}
    },
    {
      "name": "Ship order B",
      "method": "POST",
      "path": "/api/v1/orders/$dashOrderBId/ship",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "body": {
        "trackingNumber": "TRACK-DASH-B"
      },
      "capture": {}
    },
    {
      "name": "Deliver order B",
      "method": "POST",
      "path": "/api/v1/orders/$dashOrderBId/deliver",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "body": {},
      "capture": {}
    },
    {
      "name": "Create cancelled order C (should not count in dashboard)",
      "method": "POST",
      "path": "/api/v1/orders",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $buyerToken"
      },
      "body": {
        "items": [
          { "productId": "$productId", "quantity": 1 }
        ]
      },
      "capture": {
        "dashOrderCId": "data.id"
      }
    },
    {
      "name": "Cancel order C",
      "method": "POST",
      "path": "/api/v1/orders/$dashOrderCId/cancel",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $buyerToken"
      },
      "body": {
        "reason": "Changed my mind"
      },
      "capture": {}
    }
  ],
  "tests": [
    {
      "name": "GET /dashboard/sales?period=7d returns sales summary",
      "method": "GET",
      "path": "/api/v1/dashboard/sales?period=7d",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "expected": {
        "status": 200,
        "bodyHasFields": ["data.totalRevenueCents", "data.orderCount", "data.averageOrderCents"]
      }
    },
    {
      "name": "GET /dashboard/sales?period=30d returns data for 30 days",
      "method": "GET",
      "path": "/api/v1/dashboard/sales?period=30d",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "expected": {
        "status": 200,
        "bodyHasFields": ["data.totalRevenueCents", "data.orderCount", "data.averageOrderCents"]
      }
    },
    {
      "name": "GET /dashboard/top-products?limit=10 returns products sorted by revenue",
      "method": "GET",
      "path": "/api/v1/dashboard/top-products?limit=10",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "expected": {
        "status": 200,
        "bodyHasFields": ["data.items"]
      }
    },
    {
      "name": "Top products include id, name, revenueCents, unitsSold",
      "method": "GET",
      "path": "/api/v1/dashboard/top-products?limit=1",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "expected": {
        "status": 200,
        "bodyHasFields": ["data.items[0].id", "data.items[0].name", "data.items[0].revenueCents", "data.items[0].unitsSold"]
      }
    },
    {
      "name": "GET /dashboard/return-rate shows zero returns initially",
      "method": "GET",
      "path": "/api/v1/dashboard/return-rate",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "expected": {
        "status": 200,
        "body": {
          "data.returnedOrders": 0,
          "data.rate": 0
        },
        "bodyHasFields": ["data.totalOrders", "data.returnedOrders", "data.rate"]
      }
    },
    {
      "name": "Only paid/shipped/delivered orders counted (not cancelled)",
      "method": "GET",
      "path": "/api/v1/dashboard/sales?period=30d",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "expected": {
        "status": 200,
        "bodyHasFields": ["data.orderCount"]
      }
    },
    {
      "name": "Buyer cannot access dashboard returns 403",
      "method": "GET",
      "path": "/api/v1/dashboard/sales?period=7d",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $buyerToken"
      },
      "expected": {
        "status": 403,
        "bodyHasFields": ["error"]
      }
    },
    {
      "name": "Seller only sees own products data",
      "method": "GET",
      "path": "/api/v1/dashboard/sales?period=30d",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $sellerToken"
      },
      "expected": {
        "status": 200,
        "bodyHasFields": ["data.totalRevenueCents", "data.orderCount"]
      }
    },
    {
      "name": "Admin sees all data across sellers",
      "method": "GET",
      "path": "/api/v1/dashboard/sales?period=30d",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "expected": {
        "status": 200,
        "bodyHasFields": ["data.totalRevenueCents", "data.orderCount", "data.averageOrderCents"]
      }
    },
    {
      "name": "Sales data is accurate against known order amounts",
      "method": "GET",
      "path": "/api/v1/dashboard/sales?period=30d",
      "headers": {
        "X-Tenant-ID": "$tenantId",
        "Authorization": "Bearer $token"
      },
      "expected": {
        "status": 200,
        "bodyHasFields": ["data.totalRevenueCents", "data.orderCount", "data.averageOrderCents"]
      },
      "_comment": "totalRevenueCents should include order A (2 x productId.priceCents) + order B (3 x product2Id.priceCents); cancelled order C excluded"
    }
  ]
}
